# Application
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-long-random-secret
CSRF_SECRET=change-me-to-another-long-random-secret
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173

# Database
DATABASE_URL=postgresql+asyncpg://sbtb:sbtb@localhost:5432/sbtb

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
PAYMENT_WINDOW_MINUTES=20
EMAIL_ENABLED=false

# SMTP (optional — blocked on Render free; prefer Resend if you need mail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=sbtb.vasudharanade@gmail.com
SMTP_APP_PASSWORD=
SMTP_USE_TLS=true

# Resend HTTPS email (works on Render free)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Scrunchies By The Bunch <onboarding@resend.dev>

# Bootstrap primary admin on container start (password required)
BOOTSTRAP_ADMIN_EMAIL=sbtb.vasudharanade@gmail.com
BOOTSTRAP_ADMIN_NAME=Store Admin
BOOTSTRAP_ADMIN_PASSWORD=

# Object storage (use local for development)
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=./.uploads
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_PUBLIC_BASE_URL=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
